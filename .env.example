# MXID Dev Environment — template. Copy and fill: cp .env.example .env
# .env holds real local secrets and is gitignored. Keep this file secret-free.

# PostgreSQL (consumed by the dev compose postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mxid
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# MXID App (Viper env override with MXID_ prefix — wins over config.yaml).
# These mirror the POSTGRES_*/REDIS_* values above; keep them in sync.
MXID_DATABASE_HOST=host.docker.internal
MXID_DATABASE_PORT=5432
MXID_DATABASE_NAME=mxid
MXID_DATABASE_USER=postgres
MXID_DATABASE_PASSWORD=changeme
MXID_REDIS_HOST=host.docker.internal
MXID_REDIS_PORT=6379
MXID_REDIS_PASSWORD=changeme

# OIDC signing-key encryption master key (base64-encoded 32 random bytes).
# REQUIRED — the app refuses to start without it. Generate a unique one:
#   openssl rand -base64 32
# MUST be unique per deployment; rotating it invalidates all existing app
# signing keys.
MXID_CRYPTO_KEY_ENCRYPTION_KEY=
